# Copy this file to .env and fill in only the providers you use.

# audio-transcriber
GEMINI_API_KEY=your_gemini_api_key_here

# publish-assets
PUBLISH_ASSETS_PROVIDER=r2
R2_ACCESS_KEY=your_access_key_here
R2_SECRET_KEY=your_secret_key_here
R2_BUCKET=your_bucket_name_here
R2_ENDPOINT=your_r2_endpoint_here
